Algoritmo "QUESTÃO 2"
//PEDRO HENRIQUE FLORÊNCIO MOTA, 01867844

Var
       ncs : inteiro

Inicio
   escreva("ESCREVA O ANO DE NASCIMENTO: ")
   LEIA(ncs)
   se (2026 - ncs <= 18) entao
      escreva("VOCÊ ESTÁ APTO PARA VOTAR!")
   senao
      escreva("VOCÊ NÃO ESTÁ APTO PARA VOTAR!")
   fimse



Fimalgoritmo
